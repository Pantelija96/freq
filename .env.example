# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=freq

# Server
PORT=3000
NODE_ENV=development

# HTTPS Certificates (relative to project root)
CERT_KEY=./cert/server.key
CERT_CERT=./cert/server.cert

# WebSocket URL that devices will receive after login
WSS_URL=wss://192.168.1.4:3000

# Optional: Dashboard auth (we will add later)
# DASHBOARD_SECRET=super-secret-jwt-key
