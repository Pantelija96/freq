# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=freq_app
DB_PASSWORD=change-me-app-password
DB_NAME=freq
DB_ADMIN_HOST=127.0.0.1
DB_ADMIN_PORT=3306
DB_ADMIN_USER=freq_admin
DB_ADMIN_PASSWORD=change-me-admin-password

# Server
# Backend HTTP/WSS port (keep 3000 unless infrastructure requires a change)
PORT=3000
NODE_ENV=development
PUBLIC_URL=https://freq.example.com

# HTTPS Certificates (relative to project root)
CERT_KEY=./cert/server.key
CERT_CERT=./cert/server.cert

# WebSocket URL that devices will receive after login
WSS_URL=wss://freq.example.com/dashboard

# Shared secret or JWT signing key for dashboard HTTP/API access
DASHBOARD_SECRET=change-me-dashboard-secret

# Shared secret required for device provisioning requests
PROVISION_SECRET=change-me-provision-secret

# Dashboard login mode
AUTH_MODE=local
AUTH_JWT_EXPIRES_IN=12h
AUTH_LDAP_URL=
AUTH_LDAP_BASE_DN=
AUTH_LDAP_DOMAIN=
AUTH_LDAP_BIND_DN=
AUTH_LDAP_BIND_PASSWORD=

# Enable unguarded helper endpoints for local/dev work only
DEV_TOOLS_ENABLED=true
